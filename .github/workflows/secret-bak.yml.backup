name: use-secret
on:
  push:
    branches: [ main ]

jobs:
  use-secret:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Use secret from repository
        env:
          MY_SECRET: ${{ secrets.MY_SECRET }}
        run: |
          if [ -z "$MY_SECRET" ]; then
            echo "MY_SECRET is not set"
            exit 1
          fi
          echo "MY_SECRET is set and masked"
